{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Writing Environment",
  "version": "0.3.1",
  "identifier": "app.writingenvironment.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Writing Environment",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "recommends": [
          "hunspell-en-us",
          "hunspell-pt-br"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1QjNENjY0N0QzMjhERTIKUldUaWpUSjlaTmF6MVlRVnU1VjJiSzRQcWppSitZdktoODd6dDBkemVjREYxYkdKQ0Q3YnhXdmUK",
      "endpoints": [
        "https://github.com/moonknight82/writing-environment/releases/latest/download/latest.json"
      ]
    }
  }
}
