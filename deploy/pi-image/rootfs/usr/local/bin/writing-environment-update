#!/usr/bin/env bash
set -euo pipefail

archive="${1:-}"
if [[ -z "$archive" || ! -f "$archive" ]]; then
  printf 'Usage: writing-environment-update PATH-TO-PI-ARM64-ARCHIVE.tar.gz\n' >&2
  exit 2
fi

case "$archive" in
  *.tar.gz) ;;
  *) printf 'The update must be a Writing Environment .tar.gz artifact.\n' >&2; exit 2 ;;
esac

temporary="$(mktemp -d)"
trap 'rm -rf "$temporary"' EXIT

if tar -tzf "$archive" | awk '
  /^\// || /(^|\/)\.\.($|\/)/ { unsafe = 1 }
  END { exit unsafe ? 0 : 1 }
'; then
  printf 'The update archive contains an unsafe path.\n' >&2
  exit 1
fi

tar -xzf "$archive" -C "$temporary"
installer="$(find "$temporary" -mindepth 2 -maxdepth 2 -type f -name install.sh -print -quit)"
if [[ -z "$installer" ]]; then
  printf 'The update archive does not contain its installer.\n' >&2
  exit 1
fi

exec "$installer" --skip-packages --preserve-autostart
